<?xml version="1.0"?>
<config>
    <tabs>
        <ultradev translate="label">
            <label>UltraDev</label>
            <sort_order>100</sort_order>
        </ultradev>
    </tabs>

    <sections>
        <ultradev_parcelamento translate="label" module="ultradev_parcelamento">
            <label>Parcelamento</label>
            <tab>ultradev</tab>
            <frontend_type>text</frontend_type>
            <sort_order>1000</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>

            <groups>

                <general translate="label">
                    <label>Cartão de Crédito</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Habilitar Exibição</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <max_installments translate="label">
                            <label>Número Máximo de Parcelas</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Ex: 12</comment>
                        </max_installments>
                        <cash_discount translate="label">
                            <label>Desconto à Vista no Cartão (%)</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Apenas números. Ex: 5</comment>
                        </cash_discount>
                        <interest_table translate="label">
                            <label>Tabela de Juros por Parcela</label>
                            <frontend_model>ultradev_parcelamento/adminhtml_system_config_form_field_interest</frontend_model>
                            <backend_model>adminhtml/system_config_backend_serialized_array</backend_model>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment><![CDATA[Juros totais por parcela. Ex: Parcela 2 → 2.99%, Parcela 3 → 4.50%]]></comment>
                        </interest_table>
                    </fields>
                </general>

                <pix translate="label">
                    <label>Pix</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>20</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Habilitar Pix</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <discount translate="label">
                            <label>Desconto Pix (%)</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Apenas números. Ex: 5</comment>
                        </discount>
                    </fields>
                </pix>

                <boleto translate="label">
                    <label>Boleto Bancário</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>30</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Habilitar Boleto</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <discount translate="label">
                            <label>Desconto Boleto (%)</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Apenas números. Ex: 3</comment>
                        </discount>
                    </fields>
                </boleto>

                <!-- ============================================================
                     Price Box Customizado — NOVO GRUPO
                     ============================================================ -->
                <custom_price translate="label">
                    <label>Price Box Customizado</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>40</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Habilitar Price Box Customizado</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Exibe o price box no estilo unificado com o widget de parcelamento.</comment>
                        </enabled>
                    </fields>
                </custom_price>

            </groups>
        </ultradev_parcelamento>
    </sections>
</config>
